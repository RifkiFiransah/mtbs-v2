{
  "expo": {
    "slug": "mtbs-pintar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logos/logo-apk-mtbs.png",
    "scheme": "mtbspintar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logos/logo-apk-mtbs.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.firansah.mtbspintar"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logos/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logos/logo-apk-mtbs.png",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "018e15a6-8205-49ff-b5bd-50770e527f71"
      }
    }
  }
}